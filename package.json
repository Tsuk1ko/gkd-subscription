{
  "name": "@tsuk1ko/gkd-subscription",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/gkd.json5",
  "scripts": {
    "postinstall": "simple-git-hooks",
    "format": "prettier --cache --write ./**/*.{mjs,ts}",
    "lint": "eslint --cache --fix ./**/*.{mjs,ts}",
    "check": "tsc --noEmit && tsx ./scripts/check.ts",
    "build": "tsc --noEmit && tsx ./scripts/build.ts"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged",
    "pre-push": "pnpm run check"
  },
  "lint-staged": {
    "*.{js,cjs,mjs,ts,jsx,tsx}": [
      "eslint --cache --fix",
      "prettier --cache --write"
    ],
    "*.json": [
      "prettier --cache --write"
    ]
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "./dist/*.json5"
  ],
  "dependencies": {
    "@eslint/js": "^10.0.1",
    "@gkd-kit/api": "^0.9.3",
    "@gkd-kit/define": "^0.0.1",
    "@gkd-kit/tools": "^0.8.0",
    "@types/node": "^24.12.4",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-unused-imports": "^4.4.1",
    "json5": "^2.2.3",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "simple-git-hooks": "^2.13.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0"
  },
  "packageManager": "pnpm@10.34.1",
  "engines": {
    "node": ">=24"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Tsuk1ko/gkd-subscription.git"
  }
}
